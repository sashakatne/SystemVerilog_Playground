$var wire 1 8 max_slow_setup_violation_pulse $end
$var wire 1 9 max_ok_launch_q $end
$var wire 1 : max_ok_capture_d $end
$var wire 1 ; max_ok_capture_q $end
$var wire 1 < max_ok_setup_window $end
$var wire 1 = max_ok_setup_violation $end
$var wire 1 > max_ok_setup_violation_pulse $end
$var integer 32 ? min_gotcha_count $end
$var integer 32 @ max_gotcha_count $end
$var integer 32 A clean_count $end
$var integer 32 B errors $end

$scope task drive_one_cycle $end
$upscope $end

$scope module min_fast $end
$var parameter 32 C CONTAM_DELAY_PS $end
$var parameter 32 D HOLD_REQ_PS $end
$var wire 1 E clk $end
$var wire 1 F rst_n $end
