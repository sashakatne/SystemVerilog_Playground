$scope module top $end
$var parameter 32 ! CLOCK_PERIOD_PS $end
$var parameter 32 " HOLD_REQ_PS $end
$var parameter 32 # SETUP_REQ_PS $end
$var reg 1 $ clk $end
$var reg 1 % rst_n $end
$var reg 1 & launch_d $end
$var wire 1 ' min_fast_launch_q $end
$var wire 1 ( min_fast_capture_d $end
$var wire 1 ) min_fast_capture_q $end
$var wire 1 * min_fast_hold_window $end
$var wire 1 + min_fast_hold_violation $end
$var wire 1 , min_fast_hold_violation_pulse $end
$var wire 1 - min_padded_launch_q $end
$var wire 1 . min_padded_capture_d $end
$var wire 1 / min_padded_capture_q $end
$var wire 1 0 min_padded_hold_window $end
$var wire 1 1 min_padded_hold_violation $end
$var wire 1 2 min_padded_hold_violation_pulse $end
