$var reg 1 ] launch_q $end
$var wire 1 4 capture_d $end
$var reg 1 ^ capture_q $end
$var reg 1 _ setup_window $end
$var reg 1 ` setup_violation $end
$var reg 1 a setup_violation_pulse $end
$upscope $end

$scope module max_ok $end
$var parameter 32 b PROP_DELAY_PS $end
$var parameter 32 c SETUP_REQ_PS $end
